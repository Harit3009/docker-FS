// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  name String 
  email String @unique
  profilePic String?
  googleId String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)
  googleAccessToken String? @db.Text
  googleRefreshToken String? @db.Text
  rootFolderId String? @unique
  rootFolder Folder? @relation("rootFolder", fields: [rootFolderId], references: [id])
  groups GroupMember[] @relation("groupMemberUserIdRelation")
  createdFolder Folder[] @relation("userCreatedRelation")
  createdFiles File [] @relation("userCreatedRelationFile")
  ownedGroups Group[] @relation("groupOwner")
}

model Folder {
  id String @id @default(uuid()) 
  parentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdById String
  fileSystemPath String
  isDeleted Boolean @default(false)
  deletedAt DateTime?
  itemCount Int @default(0)
  size BigInt @default(0)
  createdBy User @relation("userCreatedRelation", fields: [createdById], references:[id])
  childFolders Folder[] @relation("childFolders")
  childFiles File[] @relation("parentFolderForFile")
  parent Folder? @relation("childFolders", fields: [parentId], references: [id])
  rootUser User? @relation("rootFolder")
  groups GroupFolder [] @relation("groupFolderFolderIdRelation")
  @@index([createdById,fileSystemPath])
}

model File {
  id String @id @default(uuid())
  parentId String
  s3Key String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdById String
  fileSystemPath String
  mimeType String
  size BigInt
  isDeleted Boolean @default(false)
  deletedAt DateTime? 
  createdBy User @relation("userCreatedRelationFile", fields: [createdById], references:[id])
  parentFolder Folder @relation("parentFolderForFile", fields: [parentId], references: [id])
  groups GroupFile[] @relation("groupFileFileIdRelation")
  @@index([createdById,fileSystemPath])
}

model Group {
  id String @id @default(uuid())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  ownerId String
  members GroupMember[] @relation("groupMemberGroupIdRelation")
  files GroupFile[] @relation("groupFilesGroupIdRelation")
  folders GroupFolder[] @relation("groupFolderGroupIdRelation")
  Owner User @relation("groupOwner", fields: [ownerId],references: [id],onDelete: Cascade)
  @@unique([ownerId,name])
}

model GroupMember {
  userId String 
  groupId String 
  user User @relation("groupMemberUserIdRelation",fields: [userId], references: [id],onDelete: Cascade)
  group Group @relation("groupMemberGroupIdRelation", fields: [groupId], references: [id],onDelete: Cascade)
  role GROUP_ROLE
  @@id([userId,groupId])
  @@index([groupId])
}

model GroupFile {
  fileId String 
  groupId String
  file File @relation("groupFileFileIdRelation", fields: [fileId], references: [id],onDelete: Cascade)
  group Group @relation("groupFilesGroupIdRelation", fields: [groupId], references: [id], onDelete: Cascade)
  permission RECORD_PERMISSION
  @@id([fileId,groupId])
  @@index([groupId])
}

model GroupFolder {
  folderId String 
  groupId String
  group Group @relation("groupFolderGroupIdRelation", fields: [groupId], references: [id],onDelete: Cascade)
  folder Folder @relation("groupFolderFolderIdRelation", fields: [folderId],references: [id],onDelete: Cascade)
  permission RECORD_PERMISSION
  @@id([folderId,groupId])
  @@index([groupId])
}

enum GROUP_ROLE {
  MEMBER
  ADMIN
  OWNER
  INVITED
}

enum RECORD_PERMISSION {
  READ 
  WRITE
}